# --- 必須設定 ---
# Google Cloud プロジェクトID
GCP_PROJECT_ID="gen-lang-client-xxxxx"

# リージョン (例: us-central1, asia-northeast1, global)
# Vertex AIのGeminiが利用可能なリージョンを指定してください
GCP_LOCATION="global"

# --- オプション設定 (デフォルト値が使用されるため必須ではありません) ---

# 使用するモデルID (UIで変更可能ですが、初期値を設定できます)
GEMINI_MODEL_ID=gemini-3.1-pro-preview

# 生成する最大トークン数
MAX_TOKEN=65536

GOOGLE_APPLICATION_CREDENTIALS="C:/xxxxx/gen-lang-client-xxxx-xxxx.json"

AZURE_OPENAI_ENDPOINT="<your endpoint>"
AZURE_OPENAI_API_KEY="<your key>"
AZURE_OPENAI_GPT54_DEPLOYMENT="<your deployment>"

# gpt-5.3-codex 選択時専用のデプロイ名（例：gpt-5.3-codex）
AZURE_OPENAI_CODEX_DEPLOYMENT="<your deployment>"
AZURE_OPENAI_SOL_DEPLOYMENT="<your deployment>"