# ==============================================================================
# GP-Chat Environment Variables Sample Configuration
# ==============================================================================
# このファイルは環境変数の設定サンプルです。
# 実際の環境で使用する場合は、ファイル名を ".env" に変更して、env/に配置して利用ください。
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Google Cloud / Vertex AI 設定 (必須)
# ------------------------------------------------------------------------------
# Google Cloud プロジェクトID
GCP_PROJECT_ID="your-gcp-project-id"

# リージョン (例: us-central1, asia-northeast1, global)
# Vertex AIのGeminiが利用可能なリージョンを指定してください
GCP_LOCATION="global"

# サービスアカウントキーのパス (ローカル実行時などで認証が必要な場合に設定)
GOOGLE_APPLICATION_CREDENTIALS="C:/path/to/your/service-account-file.json"


# ------------------------------------------------------------------------------
# 2. Gemini モデル・生成設定 (オプション)
# ------------------------------------------------------------------------------
# 使用するデフォルトのモデルID (UIで変更可能ですが、初期値を設定できます)
# デフォルト値: gemini-3.5-flash
GEMINI_MODEL_ID="gemini-3.5-flash"

# 生成する最大トークン数
# デフォルト値: 65536
MAX_TOKEN=65536


# ------------------------------------------------------------------------------
# 3. Azure OpenAI 設定 (オプション)
# ------------------------------------------------------------------------------
# Azure OpenAI APIを利用する場合に設定します。
# もし別の .env ファイルでAzure設定を管理したい場合は AZURE_OPENAI_ENV_FILE にパスを指定します。
AZURE_OPENAI_ENV_FILE="C:/path/to/azure.env"

# エンドポイントURLとAPIキー
AZURE_OPENAI_ENDPOINT="https://your-resource-name.openai.azure.com/"
AZURE_OPENAI_API_KEY="your-azure-openai-api-key"

# デプロイメント名
# 標準的な用途のGPTモデル (例: gpt-5.4)
AZURE_OPENAI_GPT54_DEPLOYMENT="your-gpt54-deployment-name"

コード生成・分析用のCodexモデル (例: gpt-5.3-codex)
AZURE_OPENAI_CODEX_DEPLOYMENT="your-codex-deployment-name"

その他の専用用途 (SOL等) モデル
AZURE_OPENAI_SOL_DEPLOYMENT="your-sol-deployment-name"


# ------------------------------------------------------------------------------
# 4. Cloud Logging 設定 (オプション)
# ------------------------------------------------------------------------------
# Google Cloud Loggingへのログ出力時のメタデータをカスタマイズする場合に使用します。
# 指定しない場合はデフォルト値が使用されます。

# ログ出力の有効化/無効化 (デフォルト: "true")
GP_CHAT_CLOUD_LOGGING_ENABLED="true"

GP_CHAT_LOG_SERVICE_NAME="gp-chat-app"
# GP_CHAT_LOG_LOCATION="asia-northeast1"
# GP_CHAT_LOG_REVISION_NAME="rev-001"
# GP_CHAT_LOG_CONFIGURATION_NAME="gp-chat-config"# GP_CHAT_LOG_LOCATION="asia-northeast1"
# GP_CHAT_LOG_REVISION_NAME="rev-001"
# GP_CHAT_LOG_CONFIGURATION_NAME="gp-chat-config"